    {
      "parameters": {
        "jsCode": "const mergedItem = $input.item.json;\nconst clientId = parseInt(mergedItem.client_id || mergedItem.id);\n\nconst booking = $('Extract Booking Data').item.json;\nconst startTime = booking.appointment_time;\nconst duration = parseInt(booking.duration_minutes) || 60;\n\nconst [hours, minutes] = startTime.split(':').map(Number);\nconst totalMinutes = hours * 60 + minutes + duration;\nconst endHours = Math.floor(totalMinutes / 60);\nconst endMinutes = totalMinutes % 60;\nconst endTime = `${String(endHours).padStart(2,'0')}:${String(endMinutes).padStart(2,'0')}`;\n\nreturn [{\n  json: {\n    lawyer_id: parseInt(booking.lawyer_id),\n    client_id: clientId,\n    appointment_date: booking.appointment_date,\n    start_time: startTime,\n    end_time: endTime,\n    duration_minutes: duration,\n    legal_matter_type: booking.legal_matter_type,\n    urgency_level: booking.urgency_level || 'normal',\n    status: 'scheduled',\n    consultation_type: 'initial'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        -496
      ],
