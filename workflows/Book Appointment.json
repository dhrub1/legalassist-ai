        "jsCode": "const input = $input.item.json;\n\nif (input && input.id) {\n  return [{\n    json: {\n      success: true,\n      message: \"Appointment booked successfully\",\n      appointment_id: input.id,\n      date: input.appointment_date,\n      time: input.start_time\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    success: false,\n    message: \"That time slot is no longer available. Please choose another time.\"\n  }\n}];"
