    {
      "parameters": {
        "jsCode": "const policyCheck = $('Check 24 Hour Policy').item.json;\n\nif (!policyCheck.appointment_found) {\n  return [{\n    json: {\n      success: false,\n      message: \"No scheduled appointment found for this phone number.\"\n    }\n  }];\n}\n\nif (!policyCheck.can_cancel) {\n  return [{\n    json: {\n      success: false,\n      message: \"Appointments cannot be cancelled within 24 hours. Please call our office directly at +1-555-0100.\"\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    success: true,\n    message: \"Your appointment has been successfully cancelled.\",\n    appointment_date: policyCheck.appointment_date,\n    appointment_time: policyCheck.start_time\n  }\n}];"
