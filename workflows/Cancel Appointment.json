    {
      "parameters": {
        "jsCode": "const apt = $input.item.json;\n\nif (!apt || !apt.id) {\n  return [{\n    json: {\n      can_cancel: false,\n      appointment_found: false,\n      reason: \"No scheduled appointment found\"\n    }\n  }];\n}\n\nconst aptDateTime = new Date(`${apt.appointment_date}T${apt.start_time}`);\nconst now = new Date();\nconst hoursUntil = (aptDateTime - now) / (1000 * 60 * 60);\n\nreturn [{\n  json: {\n    appointment_id: apt.id,\n    appointment_date: apt.appointment_date,\n    start_time: apt.start_time,\n    appointment_found: true,\n    can_cancel: hoursUntil > 24,\n    hours_until: Math.round(hoursUntil),\n    cancellation_reason: 'Client requested cancellation'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
