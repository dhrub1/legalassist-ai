    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body;\nconst messageType = body.message?.type || body.type || 'unknown';\n\n// Only process tool-calls messages\n// Ignore end-of-call-report, status-update etc.\nif (messageType !== 'tool-calls' && \n    !body.message?.toolCalls && \n    !body.toolCalls) {\n  \n  return [{\n    json: {\n      skip: true,\n      message_type: messageType,\n      message: `Ignoring message type: ${messageType}`\n    }\n  }];\n}\n\n// Process tool calls normally\nconst body2 = $input.item.json.body;\nlet toolCalls = null;\n\nif (body2.message && body2.message.toolCalls) {\n  toolCalls = body2.message.toolCalls;\n} else if (body2.toolCalls) {\n  toolCalls = body2.toolCalls;\n}\n\nif (!toolCalls) {\n  return [{\n    json: {\n      skip: true,\n      message: \"No toolCalls found\",\n      body_keys: Object.keys(body2),\n      message_keys: body2.message ? Object.keys(body2.message) : []\n    }\n  }];\n}\n\nconst toolCall = toolCalls[0];\nconst funcName = toolCall.function ? toolCall.function.name : toolCall.name;\nconst toolCallId = toolCall.id || toolCall.toolCallId || funcName;\n\nconst funcObj = toolCall.function || toolCall;\nconst keys = Object.keys(funcObj);\nlet funcParams = {};\n\nfor (const key of keys) {\n  if (key !== 'name' && key !== 'id') {\n    funcParams = funcObj[key];\n  }\n}\n\nif (typeof funcParams === 'string') {\n  try { funcParams = JSON.parse(funcParams); } catch(e) { funcParams = {}; }\n}\n\nreturn [{\n  json: {\n    skip: false,\n    function_name: funcName,\n    function_parameters: funcParams,\n    tool_call_id: toolCallId\n  }\n}];"
      },
