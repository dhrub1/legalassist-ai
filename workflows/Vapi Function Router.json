    {
      "parameters": {
        "jsCode": "const result = $input.item.json;\nconst toolCallId = $('Extract Function Name').item.json.tool_call_id;\n\n// Calculate date boundaries\nconst today = new Date();\nconst todayStr = today.toISOString().split('T')[0];\n\nconst maxDate = new Date();\nmaxDate.setMonth(maxDate.getMonth() + 6);\nconst maxDateStr = maxDate.toISOString().split('T')[0];\n\n// Add date context to result\nconst enrichedResult = {\n  ...result,\n  context: {\n    today: todayStr,\n    earliest_booking: new Date(today.getTime() + 86400000).toISOString().split('T')[0],\n    latest_booking: maxDateStr\n  }\n};\n\nreturn [{\n  json: {\n    results: [\n      {\n        toolCallId: toolCallId,\n        result: JSON.stringify(enrichedResult)\n      }\n    ]\n  }\n}];"
      },
